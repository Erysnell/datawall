def format_bytes(n: float) -> str:
    for unit in ('B', 'KB', 'MB', 'GB', 'TB'):
        if abs(n) < 1024.0:
            return f"{n:.1f} {unit}"
        n /= 1024.0
    return f"{n:.1f} PB"


def format_speed(n: float) -> str:
    return format_bytes(n) + '/s'


def parse_bytes(s: str) -> int:
    s = s.strip().lower()
    if s in ('off', 'none', '0'):
        return 0
    units = {'b': 1, 'kb': 1024, 'mb': 1024**2, 'gb': 1024**3, 'tb': 1024**4}
    m = re.match(r'^([\d.]+)\s*(' + '|'.join(units) + r')$', s)
    if m:
        return int(float(m.group(1)) * units[m.group(2)])
    try:
        return int(s)
    except ValueError:
        raise ValueError(f"invalid size: '{s}' (e.g. 5GB, 500MB, off)")


def log(msg: str):
    try:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        with open(LOG_PATH, 'a') as f:
            f.write(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}\n")
    except OSError:
        pass


# ── Network helpers ──────────────────────────────────────────

def get_active_interface() -> Optional[str]:
    try:
        counters = psutil.net_io_counters(pernic=True)
    except Exception as e:
        log(f"get_active_interface counters error: {e}")
        counters = {}
    try:
        stats = psutil.net_if_stats()
    except Exception as e:
        log(f"get_active_interface stats error: {e}")
        stats = {}
    for name in counters:
        if name != 'lo' and (counters[name].bytes_sent > 0 or counters[name].bytes_recv > 0):
            return name
    for name in stats:
        if name != 'lo' and stats[name].isup:
            return name
    log(f"Interfaces available: {list(counters.keys())}")
    log(f"Interfaces up: {[k for k,v in stats.items() if v.isup]}")
    return None


def get_interface_counters(iface: str) -> tuple:
    try:
        counters = psutil.net_io_counters(pernic=True)
        if iface in counters:
            c = counters[iface]
            return c.bytes_sent, c.bytes_recv
    except Exception:
        pass
    return 0, 0


def get_current_speed(iface: str) -> tuple:
    s1, r1 = get_interface_counters(iface)
    time.sleep(1)
    s2, r2 = get_interface_counters(iface)
    return max(0.0, float(s2 - s1)), max(0.0, float(r2 - r1))


def get_process_connections() -> dict:
    conns_by_pid = {}
    try:
        for conn in psutil.net_connections():
            pid = conn.pid
            if pid and pid > 0 and conn.status != 'LISTEN':
                conns_by_pid[pid] = conns_by_pid.get(pid, 0) + 1
    except Exception:
        return {}
    result = {}
    for pid, count in conns_by_pid.items():
        try:
            proc = psutil.Process(pid)
            result[str(pid)] = {'name': proc.name(), 'connections': count}
        except Exception:
            pass
    return result


def parse_ss_output(output: str) -> list:
    sockets = []
    current = {}
    for line in output.splitlines():
        if not line.strip():
            continue
        if not line[0].isspace():
            parts = line.split()
            if len(parts) >= 5:
                local = parts[3]
                remote = parts[4]
                local_is_lo = local.startswith('127.') or local.startswith('[::1]')
                remote_is_lo = remote.startswith('127.') or remote.startswith('[::1]')
                if local_is_lo and remote_is_lo:
                    current = {}
                    continue
            m = re.search(r'"([^"]+)",pid=(\d+),fd=(\d+)', line)
            if m:
                current = {'name': m.group(1), 'pid': int(m.group(2)), 'fd': int(m.group(3))}
            else:
                current = {}
        else:
            if current:
                acked = recv = None
                ma = re.search(r'bytes_acked:(\d+)', line)
                mr = re.search(r'bytes_received:(\d+)', line)
                if ma:
                    acked = int(ma.group(1))
                if mr:
                    recv = int(mr.group(1))
                if acked is not None and recv is not None:
                    sockets.append((current['pid'], current['fd'], current['name'], acked, recv))
    return sockets


def sample_sockdiag() -> list:
    try:
        r = subprocess.run(['ss', '-tpin'], capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            return parse_ss_output(r.stdout)
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        pass
    return []


def parse_ss_connections(output: str) -> list:
    sockets = []
    current = {}
    for line in output.splitlines():
        if not line.strip():
            continue
        if not line[0].isspace():
            parts = line.split()
            if len(parts) >= 5:
                local = parts[3]
                remote = parts[4]
                if local.startswith('127.') or local.startswith('[::1]'):
                    if remote.startswith('127.') or remote.startswith('[::1]'):
                        current = {}
                        continue
                current['remote'] = remote
            m = re.search(r'"([^"]+)",pid=(\d+),fd=(\d+)', line)
            if m:
                current['name'] = m.group(1)
                current['pid'] = int(m.group(2))
                current['fd'] = int(m.group(3))
            else:
                current = {}
        else:
            if current and 'name' in current and 'remote' in current:
                acked = recv = None
                ma = re.search(r'bytes_acked:(\d+)', line)
                mr = re.search(r'bytes_received:(\d+)', line)
                if ma:
                    acked = int(ma.group(1))
                if mr:
                    recv = int(mr.group(1))
                if acked is not None and recv is not None:
                    sockets.append((current['pid'], current['fd'], current['name'], current['remote'], acked, recv))
    return sockets


def sample_connections() -> list:
    try:
        r = subprocess.run(['ss', '-tpin'], capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            return parse_ss_connections(r.stdout)
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        pass
    return []


def ss_available() -> bool:
    try:
        subprocess.run(['ss', '-V'], capture_output=True, timeout=3)
        return True
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


# ── Data store ──────────────────────────────────────────────

class DataStore:
    def __init__(self):
        self.path = STORE_PATH
        self.data = self._load()

    def _load(self) -> dict:
        if self.path.exists():
            try:
                return json.loads(self.path.read_text())
            except (json.JSONDecodeError, OSError) as e:
                log(f"Corrupted store: {e}")
        return {'days': {}}

    def save(self):
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        tmp = self.path.with_suffix('.tmp')
        try:
            tmp.write_text(json.dumps(self.data, indent=2))
            tmp.replace(self.path)
        except OSError as e:
            log(f"Save error: {e}")

    def get_today(self) -> dict:
        today = date.today().isoformat()
        if today not in self.data['days']:
            self.data['days'][today] = {
                'total_sent': 0, 'total_recv': 0,
                'processes': {},
                'speed_sent': 0.0, 'speed_recv': 0.0,
            }
        return self.data['days'][today]

    def reset_today(self):
        self.data['days'].pop(date.today().isoformat(), None)
        self.save()


# ── Config ──────────────────────────────────────────────────

class Config:
    def __init__(self):
        self.path = CONFIG_PATH
        self.data = self._load()

    def _load(self) -> dict:
        if self.path.exists():
            try:
                return json.loads(self.path.read_text())
            except (json.JSONDecodeError, OSError):
                pass
        return {}

    def save(self):
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        tmp = self.path.with_suffix('.tmp')
        try:
            tmp.write_text(json.dumps(self.data, indent=2))
            tmp.replace(self.path)
        except OSError:
            pass

    def get_daily_limit(self) -> Optional[int]:
        v = self.data.get('daily_limit')
        return v if isinstance(v, int) and v > 0 else None

    def set_daily_limit(self, bytes_val: int):
        self.data['daily_limit'] = bytes_val
        self.save()

    def remove_daily_limit(self):
        self.data.pop('daily_limit', None)
        self.save()


# ── Daemon ──────────────────────────────────────────────────

def _write_pid():
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    PID_PATH.write_text(str(os.getpid()))


def _remove_pid():
    try:
        PID_PATH.unlink()
    except OSError:
        pass


def daemon_status() -> bool:
    if not PID_PATH.exists():
        return False
    try:
        pid = int(PID_PATH.read_text().strip())
        os.kill(pid, 0)
        return True
    except (OSError, ValueError):
        _remove_pid()
        return False


def daemon_start():
    if daemon_status():
        print("datawall: daemon is already running")
        return
    print("datawall: starting daemon...")
    sys.stdout.flush()
    pid = os.fork()
    if pid > 0:
        return
    os.setsid()
    pid = os.fork()
    if pid > 0:
        sys.exit(0)
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    with open(LOG_PATH, 'a') as lf, open(os.devnull, 'r') as null:
        os.dup2(null.fileno(), 0)
        os.dup2(lf.fileno(), 1)
        os.dup2(lf.fileno(), 2)
    _write_pid()
    signal.signal(signal.SIGTERM, lambda *_: _daemon_exit(0))
    log("Daemon started")
    daemon_loop()


def daemon_run():
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    signal.signal(signal.SIGINT, lambda *_: sys.exit(0))
    daemon_loop()


def _daemon_exit(code: int = 0):
    log(f"Daemon stopping (code {code})")
    _remove_pid()
    sys.exit(code)


def daemon_stop():
    if not PID_PATH.exists():
        print("datawall: daemon is not running")
        return
    try:
        pid = int(PID_PATH.read_text().strip())
        os.kill(pid, signal.SIGTERM)
        for _ in range(10):
            try:
                os.kill(pid, 0)
                time.sleep(0.5)
            except OSError:
                break
        _remove_pid()
        print("datawall: daemon stopped")
    except (OSError, ValueError) as e:
        print(f"datawall: failed to stop daemon: {e}")
        _remove_pid()


def daemon_loop():
    iface = get_active_interface()
    if not iface:
        log("No active network interface found")
        _daemon_exit(1)
    log(f"Monitoring interface: {iface}")

    store = DataStore()
    use_ss = ss_available()
    socket_cache = {}
    if use_ss:
        log("Using SOCK_DIAG (ss) for exact per-process tracking")

    while True:
        time.sleep(SAMPLE_INTERVAL)
        try:
            today = store.get_today()
            cur_tx, cur_rx = get_interface_counters(iface)
            now = time.time()

            if 'last_tx' not in today:
                today['last_tx'] = cur_tx
                today['last_rx'] = cur_rx
                today['last_time'] = now
                today['speed_sent'] = 0.0
                today['speed_recv'] = 0.0
                store.save()
                continue

            elapsed = now - today['last_time']
            if elapsed > SAMPLE_INTERVAL * 3:
                today['last_tx'] = cur_tx
                today['last_rx'] = cur_rx
                today['last_time'] = now
                today['speed_sent'] = 0.0
                today['speed_recv'] = 0.0
                socket_cache.clear()
                log(f"Large gap detected ({elapsed:.0f}s), resetting baseline")
                store.save()
                continue

            delta_tx = max(0, cur_tx - today['last_tx'])
            delta_rx = max(0, cur_rx - today['last_rx'])
            interval = max(elapsed, 0.1)
            today['speed_sent'] = round(delta_tx / interval, 1)
            today['speed_recv'] = round(delta_rx / interval, 1)

            if delta_tx > 0 or delta_rx > 0:
                today['total_sent'] += delta_tx
                today['total_recv'] += delta_rx

                if use_ss:
                    current_ss = sample_sockdiag()
                    seen = set()
                    proc_deltas = {}
                    tracked_tx = 0
                    tracked_rx = 0

                    for pid, fd, name, acked, recv in current_ss:
                        key = (pid, fd)
                        seen.add(key)
                        if key in socket_cache:
                            old_a, old_r = socket_cache[key]
                            if acked >= old_a and recv >= old_r:
                                ds = acked - old_a
                                dr = recv - old_r
                                if ds > 0 or dr > 0:
                                    if pid not in proc_deltas:
                                        proc_deltas[pid] = {'name': name, 'tx': 0, 'rx': 0}
                                    proc_deltas[pid]['tx'] += ds
                                    proc_deltas[pid]['rx'] += dr
                                    tracked_tx += ds
                                    tracked_rx += dr
                        socket_cache[key] = (acked, recv)

                    for k in list(socket_cache):
                        if k not in seen:
                            del socket_cache[k]

                    if tracked_tx > delta_tx and tracked_tx > 0:
                        scale = delta_tx / tracked_tx
                        for data in proc_deltas.values():
                            data['tx'] = int(data['tx'] * scale)
                        tracked_tx = delta_tx

                    if tracked_rx > delta_rx and tracked_rx > 0:
                        scale = delta_rx / tracked_rx
                        for data in proc_deltas.values():
                            data['rx'] = int(data['rx'] * scale)
                        tracked_rx = delta_rx

                    for data in proc_deltas.values():
                        nm = data['name']
                        if nm not in today['processes']:
                            today['processes'][nm] = {'sent': 0, 'recv': 0}
                        today['processes'][nm]['sent'] += data['tx']
                        today['processes'][nm]['recv'] += data['rx']

                    remaining_tx = max(0, delta_tx - tracked_tx)
                    remaining_rx = max(0, delta_rx - tracked_rx)
                    if remaining_tx > 0 or remaining_rx > 0:
                        if 'other' not in today['processes']:
                            today['processes']['other'] = {'sent': 0, 'recv': 0}
                        today['processes']['other']['sent'] += remaining_tx
                        today['processes']['other']['recv'] += remaining_rx
                else:
                    active = get_process_connections()
                    total_conns = sum(p['connections'] for p in active.values())
                    if total_conns > 0:
                        for info in active.values():
                            w = info['connections'] / total_conns
                            nm = info['name']
                            if nm not in today['processes']:
                                today['processes'][nm] = {'sent': 0, 'recv': 0}
                            today['processes'][nm]['sent'] += int(delta_tx * w)
                            today['processes'][nm]['recv'] += int(delta_rx * w)
                    else:
                        if 'other' not in today['processes']:
                            today['processes']['other'] = {'sent': 0, 'recv': 0}
                        today['processes']['other']['sent'] += delta_tx
                        today['processes']['other']['recv'] += delta_rx

            today['last_tx'] = cur_tx
            today['last_rx'] = cur_rx
            today['last_time'] = now
            store.save()
        except Exception as e:
            log(f"Loop error: {e}")
            time.sleep(5)


# ── Reporter ────────────────────────────────────────────────

def show_report(days: Optional[int] = None):
    if not _rich_ok:
        print("ERROR: 'rich' is required. Install with: pip install rich")
        sys.exit(1)

    store = DataStore()
    console = _RichConsole()

    if days and days > 0:
        # ── aggregate over last N days ──
        today = date.today()
        date_strings = [(today - timedelta(days=i)).isoformat() for i in range(days)]

        agg = {'total_sent': 0, 'total_recv': 0, 'processes': {}}
        days_with_data = 0
        for ds in date_strings:
            if ds in store.data['days']:
                d = store.data['days'][ds]
                agg['total_sent'] += d.get('total_sent', 0)
                agg['total_recv'] += d.get('total_recv', 0)
                for pname, pdata in d.get('processes', {}).items():
                    if pname not in agg['processes']:
                        agg['processes'][pname] = {'sent': 0, 'recv': 0}
                    agg['processes'][pname]['sent'] += pdata.get('sent', 0)
                    agg['processes'][pname]['recv'] += pdata.get('recv', 0)
                days_with_data += 1

        total_sent = agg['total_sent']
        total_recv = agg['total_recv']
        total_all = total_sent + total_recv
        procs = agg['processes']
        start_date = date_strings[days - 1]
        end_date = date_strings[0]
        title = _RichText(f"DataWall — Last {days} days ({start_date} → {end_date})", style="bold cyan")
        sub = f"Days with data: {days_with_data}/{days}"
        show_avg = True
    else:
        # ── single-day report ──
        today = store.get_today()
        total_sent = today.get('total_sent', 0)
        total_recv = today.get('total_recv', 0)
        total_all = total_sent + total_recv
        procs = today.get('processes', {})
        title = _RichText(f"DataWall — {date.today().isoformat()}", style="bold cyan")
        iface = get_active_interface()
        if iface:
            up, down = get_current_speed(iface)
            sub = f"Speed:  ↑ {format_speed(up)}  ↓ {format_speed(down)}   [{iface}]"
        else:
            sub = "Speed:  [dim]not available[/dim]"
        sub = _limit_warning(total_all) + sub
        show_avg = False

    table = _RichTable(box=_rich_box.HEAVY, header_style="bold magenta")
    table.add_column("Program")
    table.add_column("Sent", justify="right", style="yellow")
    table.add_column("Received", justify="right", style="green")
    table.add_column("Total", justify="right", style="cyan")
    if show_avg:
        table.add_column("Avg/day", justify="right", style="blue")
    table.add_column("%", justify="left")

    sorted_procs = sorted(
        procs.items(),
        key=lambda x: x[1]['sent'] + x[1]['recv'],
        reverse=True
    )
    for pname, pdata in sorted_procs:
        ps = pdata['sent']
        pr = pdata['recv']
        pt = ps + pr
        pct = (pt / total_all * 100) if total_all > 0 else 0
        n = max(1, int(pct / 100 * 10))
        bar = '█' * n + '░' * (10 - n)
        row = [pname, format_bytes(ps), format_bytes(pr), format_bytes(pt)]
        if show_avg:
            row.append(format_bytes(pt / days_with_data))
        row.append(f"{bar} {pct:5.1f}%")
        table.add_row(*row)

    total_row = [
        "[bold]TOTAL[/bold]",
        f"[bold]{format_bytes(total_sent)}[/bold]",
        f"[bold]{format_bytes(total_recv)}[/bold]",
        f"[bold]{format_bytes(total_all)}[/bold]",
    ]
    if show_avg:
        total_row.append(f"[bold]{format_bytes(total_all / days_with_data)}[/bold]")
    total_row.append("")
    table.add_row(*total_row)

    panel = _RichPanel(table, title=title, subtitle=sub, border_style="cyan", padding=(1, 2))
    console.print()
    console.print(panel)

    if not days:
        running = daemon_status()
        sc = "green" if running else "red"
        console.print(f"  Daemon: [{sc}]{'running' if running else 'stopped'}[/{sc}]    ")
        console.print()


# ── Watch mode ──────────────────────────────────────────────

def watch_mode():
    if not _rich_ok:
        print("ERROR: 'rich' is required. Install with: pip install rich")
        sys.exit(1)

    iface = get_active_interface()
    daemon_alive = daemon_status()
    console = _RichConsole()

    speed_cache = {}
    old_tx = old_rx = None
    interval = 2.0

    try:
        with _RichLive("", screen=True, refresh_per_second=2, console=console) as live:
            while True:
                time.sleep(interval)

                cur_ss = sample_sockdiag()
                if iface:
                    cur_tx, cur_rx = get_interface_counters(iface)
                else:
                    cur_tx = cur_rx = 0

                # per-process speeds from socket cache
                proc_speed = {}
                seen = set()
                ss_tx = ss_rx = 0

                for pid, fd, name, acked, recv in cur_ss:
                    key = (pid, fd)
                    seen.add(key)
                    if key in speed_cache:
                        old_a, old_r = speed_cache[key]
                        if acked >= old_a and recv >= old_r:
                            ds = acked - old_a
                            dr = recv - old_r
                            if ds > 0 or dr > 0:
                                if name not in proc_speed:
                                    proc_speed[name] = {'tx': 0.0, 'rx': 0.0}
                                proc_speed[name]['tx'] += ds
                                proc_speed[name]['rx'] += dr
                                ss_tx += ds
                                ss_rx += dr
                    speed_cache[key] = (acked, recv)

                for k in list(speed_cache):
                    if k not in seen:
                        del speed_cache[k]

                # convert to bytes/sec
                for name in proc_speed:
                    proc_speed[name]['tx'] /= interval
                    proc_speed[name]['rx'] /= interval

                # interface deltas in this interval
                iface_tx = cur_tx - old_tx if old_tx is not None else 0
                iface_rx = cur_rx - old_rx if old_rx is not None else 0
                old_tx, old_rx = cur_tx, cur_rx

                # timing correction
                if ss_tx > iface_tx and ss_tx > 0:
                    scale = iface_tx / ss_tx
                    for name in proc_speed:
                        proc_speed[name]['tx'] *= scale
                    ss_tx = iface_tx
                if ss_rx > iface_rx and ss_rx > 0:
                    scale = iface_rx / ss_rx
                    for name in proc_speed:
                        proc_speed[name]['rx'] *= scale
                    ss_rx = iface_rx

                # residual "other" speed
                other_tx = max(0.0, iface_tx / interval - ss_tx / interval) if old_tx is not None else 0.0
                other_rx = max(0.0, iface_rx / interval - ss_rx / interval) if old_rx is not None else 0.0
                if other_tx > 0 or other_rx > 0:
                    proc_speed['other'] = {'tx': other_tx, 'rx': other_rx}

                # daily totals from store (reload each iteration to pick up daemon updates)
                today = DataStore().get_today()
                total_sent = today.get('total_sent', 0)
                total_recv = today.get('total_recv', 0)
                total_all = total_sent + total_recv
                proc_store = today.get('processes', {})

                # build table
                table = _RichTable(box=_rich_box.HEAVY, header_style="bold magenta")
                table.add_column("Program", no_wrap=True)
                table.add_column("Down ▼", justify="right", style="green")
                table.add_column("Up ▲", justify="right", style="yellow")
                table.add_column("Total today", justify="right", style="cyan")
                table.add_column("%", justify="left")

                merged = set(list(proc_speed.keys()) + list(proc_store.keys()))
                rows = []
                for name in merged:
                    tx = proc_speed.get(name, {}).get('tx', 0.0)
                    rx = proc_speed.get(name, {}).get('rx', 0.0)
                    pdata = proc_store.get(name, {})
                    ps = pdata.get('sent', 0)
                    pr = pdata.get('recv', 0)
                    pt = ps + pr
                    pct = (pt / total_all * 100) if total_all > 0 else 0
                    rows.append((name, tx, rx, pt, pct))

                rows.sort(key=lambda r: r[4] if r[3] > 0 else r[1] + r[2], reverse=True)

                for name, tx, rx, pt, pct in rows:
                    n = max(1, int(pct / 100 * 10))
                    bar = '█' * n + '░' * (10 - n)
                    table.add_row(
                        name,
                        format_speed(rx) if rx > 0 else "[dim]—[/dim]",
                        format_speed(tx) if tx > 0 else "[dim]—[/dim]",
                        format_bytes(pt),
                        f"{bar} {pct:5.1f}%" if pt > 0 else ""
                    )

                total_tx_speed = (iface_tx / interval) if old_tx is not None else 0.0
                total_rx_speed = (iface_rx / interval) if old_rx is not None else 0.0
                table.add_row(
                    "[bold]TOTAL[/bold]",
                    f"[bold]{format_speed(total_rx_speed)}[/bold]",
                    f"[bold]{format_speed(total_tx_speed)}[/bold]",
                    f"[bold]{format_bytes(total_all)}[/bold]",
                    ""
                )

                title = _RichText(f"DataWall Watch — {date.today().isoformat()}", style="bold cyan")
                sub = _limit_warning(total_all) + f"  Daemon: {'running' if daemon_alive else 'stopped'}  Interface: {iface or 'N/A'}  Ctrl+C to quit"
                panel = _RichPanel(table, title=title, subtitle=sub, border_style="cyan", padding=(1, 1))
                live.update(panel)

    except KeyboardInterrupt:
        pass


# ── Limit / alert helpers ───────────────────────────────────

def _limit_warning(total_bytes: int) -> str:
    cfg = Config()
    limit = cfg.get_daily_limit()
    if limit is None or total_bytes <= 0:
        return ''
    pct = total_bytes / limit * 100
    if pct >= 100:
        return f"[bold red]⚠ EXCEEDED: {format_bytes(total_bytes)} / {format_bytes(limit)} ({pct:.0f}%)[/bold red]  |  "
    if pct >= 80:
        return f"[bold yellow]⚠ Near limit: {format_bytes(total_bytes)} / {format_bytes(limit)} ({pct:.0f}%)[/bold yellow]  |  "
    return ''


def limit_mode(arg: Optional[str] = None):
    cfg = Config()
    if arg is None:
        limit = cfg.get_daily_limit()
        store = DataStore()
        today = store.get_today()
        total = today.get('total_sent', 0) + today.get('total_recv', 0)
        if limit:
            pct = total / limit * 100
            print(f"datawall: daily limit: {format_bytes(limit)}  ({format_bytes(total)} used — {pct:.1f}%)")
        else:
            print("datawall: no daily limit set")
        return
    try:
        b = parse_bytes(arg)
    except ValueError as e:
        print(f"datawall: {e}")
        sys.exit(1)
    if b <= 0:
        cfg.remove_daily_limit()
        print("datawall: daily limit removed")
    else:
        cfg.set_daily_limit(b)
        print(f"datawall: daily limit set to {format_bytes(b)}")


# ── Connections viewer ──────────────────────────────────────

def show_connections():
    if not _rich_ok:
        print("ERROR: 'rich' is required. Install with: pip install rich")
        sys.exit(1)

    raw = sample_connections()
    if not raw:
        console = _RichConsole()
        console.print("[yellow]No active TCP connections found.[/yellow]")
        return

    agg = {}
    prog_totals = {}
    for _pid, _fd, name, remote, acked, recv in raw:
        key = (name, remote)
        if key not in agg:
            agg[key] = {'sent': 0, 'recv': 0}
        agg[key]['sent'] += acked
        agg[key]['recv'] += recv
        if name not in prog_totals:
            prog_totals[name] = {'sent': 0, 'recv': 0}
        prog_totals[name]['sent'] += acked
        prog_totals[name]['recv'] += recv

    rows = []
    for (name, remote), data in agg.items():
        total = data['sent'] + data['recv']
        pt = prog_totals[name]['sent'] + prog_totals[name]['recv']
        pct = (total / pt * 100) if pt > 0 else 0
        rows.append((name, remote, data['sent'], data['recv'], total, pct))

    rows.sort(key=lambda r: r[4], reverse=True)

    console = _RichConsole()
    table = _RichTable(box=_rich_box.HEAVY, header_style="bold magenta")
    table.add_column("Program", no_wrap=True)
    table.add_column("Remote", no_wrap=True)
    table.add_column("Sent", justify="right", style="yellow")
    table.add_column("Received", justify="right", style="green")
    table.add_column("Total", justify="right", style="cyan")
    table.add_column("%", justify="left")

    for name, remote, sent, recv, total, pct in rows:
        n = max(1, int(pct / 100 * 10))
        bar = '█' * n + '░' * (10 - n)
        table.add_row(
            name, remote,
            format_bytes(sent) if sent > 0 else "[dim]—[/dim]",
            format_bytes(recv) if recv > 0 else "[dim]—[/dim]",
            format_bytes(total),
            f"{bar} {pct:5.1f}%"
        )

    title = _RichText("DataWall — Active Connections", style="bold cyan")
    panel = _RichPanel(table, title=title, border_style="cyan", padding=(1, 2))
    console.print()
    console.print(panel)
    console.print(f"  {len(rows)} connections across {len(prog_totals)} programs    ")
    console.print()


# ── CLI ─────────────────────────────────────────────────────

def main():
    if psutil is None:
        print("ERROR: 'psutil' is required. Install with: pip install psutil")
        sys.exit(1)

    p = argparse.ArgumentParser(
        description="datawall — Network data usage tracker per program",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
commands:
  datawall              show daily usage report (default)
  datawall start        start background daemon (fork)
  datawall run          run daemon in foreground (for systemd)
  datawall stop         stop background daemon
  datawall restart      restart the daemon
  datawall status       check if daemon is running
  datawall reset        reset today's accumulated data
  datawall watch        real-time bandwidth monitor (htop-like)
  datawall days N       aggregated report for last N days
  datawall limit        show current daily limit and usage
  datawall limit SIZE   set daily limit (e.g. 5GB, 500MB)
  datawall limit off    remove daily limit
  datawall connections  show active TCP connections per program
        """
    )
    p.add_argument(
        'command', nargs='?', default='report',
        choices=['report', 'start', 'run', 'daemon', 'stop', 'restart', 'status', 'reset', 'watch', 'days', 'limit', 'connections']
    )
    p.add_argument('arg1', nargs='?', type=str, default=None,
                   help=argparse.SUPPRESS)

    args = p.parse_args()

    if args.command == 'start':
        daemon_start()
    elif args.command in ('run', 'daemon'):
        daemon_run()
    elif args.command == 'stop':
        daemon_stop()
    elif args.command == 'restart':
        daemon_stop()
        time.sleep(1)
        daemon_start()
    elif args.command == 'status':
        print("datawall: daemon is", "running" if daemon_status() else "stopped")
    elif args.command == 'reset':
        DataStore().reset_today()
        print("datawall: today's data has been reset")
    elif args.command == 'watch':
        watch_mode()
    elif args.command == 'days':
        try:
            n = int(args.arg1) if args.arg1 else None
        except ValueError:
            n = None
        if n is None or n < 1:
            print("datawall: usage: datawall days N")
            sys.exit(1)
        show_report(days=n)
    elif args.command == 'limit':
        limit_mode(args.arg1)
    elif args.command == 'connections':
        show_connections()
    else:
        show_report()


if __name__ == '__main__':
    main()
