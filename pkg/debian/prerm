#!/bin/sh
set -e

# Stop any running datawall daemon processes
if command -v systemctl >/dev/null 2>&1; then
    # Try stopping the user service for all users
    for d in /home/* /root; do
        uid=$(id -u "$(basename "$d")" 2>/dev/null || true)
        [ -z "$uid" ] && continue
        systemctl --machine="$uid@.host" --user stop datawall.service 2>/dev/null || true
    done
fi

# Fallback: kill any datawall daemon by exact command match
pkill -f "^python3 .*datawall " 2>/dev/null || true

exit 0
